{
  "name": "ai-ecommerce-assistant",
  "version": "1.0.0",
  "description": "AI驱动的电商智能助手平台",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd src/backend && uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd src/frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd src/backend && pip install -r requirements.txt",
    "build:frontend": "cd src/frontend && npm run build",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd src/backend && python -m pytest tests/ -v",
    "test:frontend": "cd src/frontend && npm run test",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "deploy": "npm run build && npm run docker:up"
  },
  "keywords": [
    "ai",
    "ecommerce",
    "assistant",
    "machine-learning",
    "analytics",
    "automation"
  ],
  "author": "OpenClaw AI",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}